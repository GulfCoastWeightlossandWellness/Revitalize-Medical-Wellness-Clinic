# Copy this file to .env.local and fill in real values before deploying.
# Do NOT commit .env.local to git.

# ───────────────────────────────────────────────────────────────────────────
# Google Analytics 4 Measurement ID
# Found in: GA4 → Admin → Data Streams → your stream → Measurement ID
# ───────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# ───────────────────────────────────────────────────────────────────────────
# Phase 2 — Scheduled blog publishing
# ───────────────────────────────────────────────────────────────────────────

# Vercel Deploy Hook URL — manually create at:
#   Vercel Dashboard → Project → Settings → Git → Deploy Hooks
# Click "Create Hook", name it "Drop Scheduled Content", select branch "main",
# then copy the generated URL here AND add it as an environment variable in
# the Vercel project (Settings → Environment Variables → Production).
# This URL is what /api/cron/drop-content POSTs to in order to trigger a
# fresh build that re-evaluates isPublished() against the new clock.
VERCEL_DEPLOY_HOOK_URL=https://api.vercel.com/v1/integrations/deploy/...

# ───────────────────────────────────────────────────────────────────────────
# CRON_SECRET — DO NOT SET MANUALLY in .env.local
# ───────────────────────────────────────────────────────────────────────────
# Vercel auto-injects this at runtime whenever a "crons" entry exists in
# vercel.json. The value is generated by Vercel and rotated per deployment;
# it's automatically passed in the Authorization header of every cron
# invocation as `Bearer ${CRON_SECRET}`. The cron route handler reads it
# from process.env to validate inbound requests.
#
# You only need this listed here so contributors know it exists; leave the
# value blank locally. It will only ever be defined in Vercel's runtime env.
CRON_SECRET=

# Google Search Console HTML verification (if used): static file lives at
# public/google6217edd756051041.html → served at /google6217edd756051041.html
